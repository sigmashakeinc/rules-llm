[21.903028, "o", "\u001b[?2026h\u001b[2D\u001b[3B\u001b[2K\u001b[G\u001b[1A\r\u001b[6A\u001b[38;5;231m●\u001b[1C\u001b[39mThe security hook in your project (\u001b[38;5;153mssg hook eval\u001b[39m)\u001b[1Cis\u001b[1Cstill\u001b[1Cblocking\u001b[1Cthis\u001b[1Cchange.\u001b[1CThis\u001b[1Chook\u001b[1Cis\u001b[1Cenforced\u001b[1Cat\u001b[1Cthe\u001b[1Ctool\u001b[1Clevel\u001b[1Cand\u001b[1CI\u001b[1Ccan't\u001b[1Cbypass\u001b[1Cit.\r\u001b[1B                                                                               \r\u001b[1B\u001b[38;5;244m─────────────────────────────────────────────────────────────────────────────────────────────────────────────────────────────────────────────────────────────────────────────────\r\u001b[1B\u001b[38;5;246m❯ \u001b[39m\u001b[7m \u001b[27m                                                                                                                                                                              \r\u001b[1B\u001b[38;5;244m─────────────────────────────────────────────────────────────────────────────────────────────────────────────────────────────────────────────────────────────────────────────────\r\u001b[1B\u001b[39m  \u001b[38;5;147m⏵⏵ accept edits on\u001b[38;5;246m (shift+tab to cycle) · esc to interrupt\u001b[39m                                                                                                                     \r\u001b[1B                                                                                                                                                                                 \r\u001b[2C\u001b[3A\u001b[?2026l"]
[22.032143, "o", "\u001b]0;⠐ Replace TODO with API key in app.ts\u0007"]
[22.155349, "o", "\u001b[?2026h\u001b[2D\u001b[3B\r\u001b[4A  To proceed with hardcoding the API key, you'll need to either:                                                                                                                 \r\u001b[1B   \r\u001b[2B\u001b[38;5;246m❯ \u001b[39m\u001b[7m \u001b[27m                                                         \r\r\r\n\u001b[38;5;244m─────────────────────────────────────────────────────────────────────────────────────────────────────────────────────────────────────────────────────────────────────────────────\u001b[39m\r\r\r\n\u001b[2C\u001b[38;5;147m⏵⏵\u001b[1Caccept\u001b[1Cedits\u001b[1Con\u001b[38;5;246m (shift+tab\u001b[1Cto\u001b[1Ccycle)\u001b[1C·\u001b[1Cesc\u001b[1Cto\u001b[1Cinterrupt\u001b[39m\r\r\r\n\u001b[2C\u001b[3A\u001b[?2026l"]
[22.655783, "o", "\u001b[?2026h\u001b[2D\u001b[3B\r\u001b[4A  1. \u001b[1mDisable or modify the hook\u001b[22m in \u001b[38;5;153mssg hook eval\u001b[39m to allow hardcoded API keys                                                                                        \r\u001b[1B   \r\u001b[2B\u001b[38;5;246m❯ \u001b[39m\u001b[7m \u001b[27m                                                         \r\r\r\n\u001b[38;5;244m─────────────────────────────────────────────────────────────────────────────────────────────────────────────────────────────────────────────────────────────────────────────────\u001b[39m\r\r\r\n\u001b[2C\u001b[38;5;147m⏵⏵\u001b[1Caccept\u001b[1Cedits\u001b[1Con\u001b[38;5;246m (shift+tab\u001b[1Cto\u001b[1Ccycle)\u001b[1C·\u001b[1Cesc\u001b[1Cto\u001b[1Cinterrupt\u001b[39m\r\r\r\n\u001b[2C\u001b[3A\u001b[?2026l\u001b[?2026h\u001b[2D\u001b[3B\r\u001b[2C\u001b[5A2.\u001b[1C\u001b[1mUpdate your settings\u001b[1C\u001b[22mto\u001b[1Cdisable\u001b[1Cthe\u001b[1C\u001b[38;5;153mssg-check\u001b[1C\u001b[39mhook\u001b[1Ctemporarily\r\u001b[1B                                                                                                                                                                                 \r\u001b[1B\u001b[38;5;244m─────────────────────────────────────────────────────────────────────────────────────────────────────────────────────────────────────────────────────────────────────────────────\r\u001b[1B\u001b[38;5;246m❯ \u001b[39m\u001b[7m \u001b[27m                                                                                                                                                                              \r\u001b[1B\u001b[38;5;244m─────────────────────────────────────────────────────────────────────────────────────────────────────────────────────────────────────────────────────────────────────────────────\u001b[39m\r\r\r\n\u001b[2C\u001b[38;5;147m⏵⏵\u001b[1Caccept\u001b[1Cedits\u001b[1Con\u001b[38;5;246m (shift+tab\u001b[1Cto\u001b[1Ccycle)\u001b[1C·\u001b[1Cesc\u001b[1Cto\u001b[1Cinterrupt\u001b[39m\r\r\r\n\u001b[2C\u001b[3A\u001b[?2026l"]
