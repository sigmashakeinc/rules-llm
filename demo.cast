[22.676835, "o", "\u001b[?2026h\u001b[2D\u001b[3B\r\u001b[4A                                                                                                                                                                                 \r\u001b[1B  \u001b[48;5;237m\u001b[38;5;239m❯ \u001b[38;5;231myes\u001b[39m                                                                                                                                                                        \r\u001b[2B\u001b[49m\u001b[38;5;246m❯ \u001b[39m\u001b[7mP\u001b[27m\u001b[2mress up to edit queued messages\u001b[22m                          \r\r\r\n\u001b[38;5;244m─────────────────────────────────────────────────────────────────────────────────────────────────────────────────────────────────────────────────────────────────────────────────\u001b[39m\r\r\r\n\u001b[2C\u001b[38;5;147m⏵⏵\u001b[1Caccept\u001b[1Cedits\u001b[1Con\u001b[38;5;246m (shift+tab\u001b[1Cto\u001b[1Ccycle)\u001b[1C·\u001b[1Cesc\u001b[1Cto\u001b[1Cinterrupt\u001b[39m\r\r\r\n\u001b[2C\u001b[3A\u001b[?2026l"]
[22.699126, "o", "\u001b[?2026h\u001b[2D\u001b[3B\r\u001b[2C\u001b[10A1.\u001b[1C\u001b[1mDisable or modify the hook\u001b[1C\u001b[22min\u001b[1C\u001b[38;5;153mssg hook eval\u001b[1C\u001b[39mto\u001b[1Callow\u001b[1Chardcoded\u001b[1CAPI\u001b[1Ckeys\r\u001b[2C\u001b[1B2\u001b[2C\u001b[1mUpd\u001b[1Cte y\u001b[1Cur settings\u001b[22m to disable the \u001b[38;5;153mssg-check\u001b[39m hook temporarily   \u001b[1C         \u001b[1C   \u001b[1C    \r\u001b[2C\u001b[1B  \u001b[1C                    \u001b[1C  \u001b[1C       \u001b[1C   \u001b[1C         \u001b[1C    \u001b[1C           \r\u001b[2C\u001b[1BWould\u001b[1Cyou\u001b[1Clike\u001b[1Cme\u001b[1Cto\u001b[1Chelp\u001b[1Cyou\u001b[1Cmodify\u001b[1Cthe\u001b[1Chook\u001b[1Cconfiguration,\u001b[1Cor\u001b[1Cwould\u001b[1Cyou\u001b[1Cprefer\u001b[1Ca\u001b[1Cdifferent\u001b[1Capproach?\r\u001b[2B\u001b[38;5;174m✢\u001b[1CGarni\u001b[38;5;216mshi\u001b[38;5;174mng… \u001b[39m                                                                                                                                                                 \r\u001b[1B\u001b[38;5;246m  ⎿  Tip: Double-tap esc to rewind the conversation to a previous point in time\u001b[39m                                                                                                  \r\u001b[1B                                  \r\u001b[1B                                                                                                                                                                                 \r\u001b[2C\u001b[1B\u001b[48;5;237m\u001b[38;5;239m❯ \u001b[38;5;231myes\u001b[39m                                                                                                                                                                        \u001b[49m\r\r\r\n\u001b[38;5;244m─────────────────────────────────────────────────────────────────────────────────────────────────────────────────────────────────────────────────────────────────────────────────\u001b[39m\r\r\r\n\u001b[38;5;246m❯ \u001b[39m\u001b[7mP\u001b[27m\u001b[2mress\u001b[1Cup\u001b[1Cto\u001b[1Cedit\u001b[1Cqueued\u001b[1Cmessages\u001b[22m\r\r\r\n\u001b[38;5;244m─────────────────────────────────────────────────────────────────────────────────────────────────────────────────────────────────────────────────────────────────────────────────\u001b[39m\r\r\r\n\u001b[2C\u001b[38;5;147m⏵⏵\u001b[1Caccept\u001b[1Cedits\u001b[1Con\u001b[38;5;246m (shift+tab\u001b[1Cto\u001b[1Ccycle)\u001b[1C·\u001b[1Cesc\u001b[1Cto\u001b[1Cinterrupt\u001b[39m\r\r\r\n\u001b[2C\u001b[3A\u001b[?2026l"]
